# MongoDB
MONGO_URI=mongodb://mongo:27017/finpay

# Redis
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_
JWT_PUBLIC_

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://auth-service:3001

# Wallet Service
WALLET_SERVICE_PORT=3002
WALLET_SERVICE_URL=http://wallet-service:3002

# Transaction Service
TRANSACTION_SERVICE_PORT=3003
TRANSACTION_SERVICE_URL=http://transaction-service:3003

# API Gateway
API_GATEWAY_PORT=3000

# Logging
LOG_LEVEL=info

# Resend (Phase 4)
RESEND_API_KEY=
